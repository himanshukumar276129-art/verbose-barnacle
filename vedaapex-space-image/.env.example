# VedaApex Space Image - NASA + Multi-Provider Backend

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=VedaApex Space Image
APP_VERSION=1.0.0
APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================================================
# NASA API CONFIGURATION
# ============================================================================
NASA_API_URL=https://images-api.nasa.gov/search
NASA_DEMO_KEY=DEMO_KEY

# ============================================================================
# PROVIDER CONFIGURATION
# ============================================================================
ENABLED_PROVIDERS=nasa,wikimedia,pexels
DEFAULT_PROVIDER=nasa

# Provider Priority for Query Types
SPACE_QUERY_PRIORITY=nasa,wikimedia,pexels
SCIENTIFIC_QUERY_PRIORITY=wikimedia,nasa,pexels
GENERAL_QUERY_PRIORITY=pexels,wikimedia,nasa

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
CACHE_ENABLED=true
CACHE_TYPE=memory
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0
CACHE_MAX_SIZE=1000

# ============================================================================
# REQUEST CONFIGURATION
# ============================================================================
REQUEST_TIMEOUT=15
MAX_RESULTS=50
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=20

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================
MIN_QUERY_LENGTH=2
MAX_QUERY_LENGTH=200
DEDUPLICATION_ENABLED=true
RANKING_ENABLED=true
