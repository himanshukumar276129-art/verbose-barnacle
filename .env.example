# Application
APP_NAME=VedaApex Search Aggregation
APP_VERSION=1.0.0
APP_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# API Keys
PEXELS_API_KEY=your_pexels_key_here
NASA_API_KEY=DEMO_KEY
WIKIMEDIA_API_KEY=

# Provider Settings
ENABLE_PEXELS=true
ENABLE_WIKIMEDIA=true
ENABLE_NASA=true

# Cache Settings
CACHE_ENABLED=true
CACHE_TYPE=memory
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0

# Request Settings
REQUEST_TIMEOUT=15
MAX_RESULTS=50
DEFAULT_PAGE_SIZE=20

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Query Settings
MIN_QUERY_LENGTH=2
MAX_QUERY_LENGTH=200

# CORS
CORS_ORIGINS=["*"]
