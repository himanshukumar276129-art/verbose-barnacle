# =========================================================================
# VedaApex SaaS AI Media & Core API Hub Environment Configurations
# =========================================================================

# ─── CORE SECURITY CONFIGURATIONS ────────────────────────────────────────
# Change this secret key in production! Can generate using: openssl rand -hex 32
SECRET_KEY=SUPER_SECRET_KEY_CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── DATABASE & BROKER CONNECTIVITY ──────────────────────────────────────
# Default SQLite workspace configuration (supports instant dev startup)
DATABASE_URL=sqlite:///./vedaapex.db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Celery Redis Message Broker & sliding-window rate limit cache URL
REDIS_URL=redis://localhost:6379/0

# ─── STORAGE CONFIGURATIONS ──────────────────────────────────────────────
# When these cloud credentials are provided, VedaApex automatically uploads
# output media files to S3 or Cloudflare R2 and serves direct download URLs.
# If these fields are omitted or blank, the storage subsystem falls back to
# local storage, serving media downloads via FastAPI StaticFiles on port 8000.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=

# ─── WEBHOOK BINDINGS ───────────────────────────────────────────────────
# Endpoint URL to broadcast status payloads on task completion/failure
WEBHOOK_NOTIFICATION_URL=

# ─── ADVANCED THIRD-PARTY INTEGRATED APIS ───────────────────────────────
# API key tiers integrated inside the core billing routers of VedaApex
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
DOCUMENT_COMPILER_KEY=

# Razerpay API Integrations for Stripe/Payment Gateways
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_MIN_AMOUNT_PAISA=1000

# Ollama Local AI Base URL
OLLAMA_API_BASE=http://localhost:11434/v1

